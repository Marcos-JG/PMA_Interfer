            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nivelImpacto\": \"Medio\",\n  \"estado\": \"Activo\",\n  \"descripcion\": \"Actualizacion de informacion de la empresa.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/empresas/{{empresa_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "empresas",
                "{{empresa_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Generar Reporte Excel",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{auth_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/empresas/reporte/excel",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "empresas",
                "reporte",
                "excel"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
